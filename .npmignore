# Development files
.git
.gitignore
node_modules/
.DS_Store
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test files
test/
tests/
*.test.js
*.spec.js
__tests__/
coverage/

# Documentation (keep README.md)
docs/
*.md
!README.md

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.editorconfig

# Build artifacts
dist/
build/
*.tgz

# Temporary files
*.tmp
*.temp
tmp/
temp/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Examples (too large)
examples/

# Font download cache (fonts are downloaded on install)
assets/fonts/*.otf
assets/fonts/*.ttf
!assets/fonts/LICENSE.md

# References
references/

# Outputs
outputs/
